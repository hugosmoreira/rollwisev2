# RollWise environment variables
#
# Copy this file to `.env.local` and fill in your own values.
# Only the anon/public key belongs in the frontend.
# NEVER place the Supabase service-role key in this app (project hard rule).

# Stripe — ONLY the publishable key may live in the frontend (optional; the
# Checkout redirect flow doesn't strictly need it). The SECRET key and the
# webhook signing secret are set as Supabase Edge Function secrets, NEVER here.
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://ikwwcacirwpkdyjwfqei.supabase.co
VITE_SUPABASE_ANON_KEY=

# DO NOT put STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET here (or in .env.local).
# Those are Supabase Edge Function secrets — set them in the Supabase dashboard
# (Edge Functions → Secrets) or with `supabase secrets set ...`. See supabase/STRIPE.md.